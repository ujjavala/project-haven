# Copy this file to .env and adjust values before running docker compose
# docker compose --env-file .env up --build

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── Postgres (shared password for all DB containers) ─────────────────────────
POSTGRES_PASSWORD=haven

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# Default guest/guest is fine for local development only.
# RABBITMQ_USER=haven
# RABBITMQ_PASSWORD=changeme

# ── Nous Hermes 2 via Ollama ──────────────────────────────────────────────────
# Ollama runs as a Docker service — no host installation needed.
# On first start, the ollama-init container pulls the model automatically.
# The model is cached in the ollama-data Docker volume for fast subsequent starts.
#
# No prerequisites beyond Docker Desktop.
#
# HERMES_MODEL — Ollama model name. Change to swap models.
#                Also update the ollama-init entrypoint in docker-compose.yml.
HERMES_MODEL=nous-hermes2

# ── NASA FIRMS (fire detection) ───────────────────────────────────────────────
# Free MAP_KEY from https://firms.modaps.eosdis.nasa.gov/api/
# Used by prediction-service to pull real VIIRS NRT fire detections within 3 hours.
# Without this key the service falls back to VIC Emergency + NSW RFS live feeds,
# then GA fire-prone polygons, then static seed data.
NASA_FIRMS_MAP_KEY=your-nasa-firms-map-key-here

# ── GrantConnect (federal grants) ────────────────────────────────────────────
# API key from https://www.grants.gov.au/Web/Content/Content?id=Api
# Used by recommendation-service to pull live federal bushfire/disaster grants.
# Without this key only the curated static grant list is used.
GRANTCONNECT_API_KEY=your-grantconnect-api-key-here
