# Copy this file to .env and adjust values before running docker compose
# docker compose --env-file .env up --build

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── Postgres (shared password for all DB containers) ─────────────────────────
POSTGRES_PASSWORD=haven

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# Default guest/guest is fine for local development only.
# RABBITMQ_USER=haven
# RABBITMQ_PASSWORD=changeme

# ── Hermes / Nous Research Inference API ──────────────────────────────────────
# This key serves two purposes:
#   1. LLM_API_KEY — used by the Hermes Agent container to call inference-api.nousresearch.com
#   2. API_SERVER_KEY — authenticates api-gateway → Hermes Agent requests
# Get your key from https://portal.nousresearch.com
HERMES_API_KEY=your-nous-research-api-key-here
